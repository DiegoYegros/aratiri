<FindBugsFilter>
    <Match>
        <!-- Generated LND protobuf/gRPC code is produced by the Gradle protobuf plugin and is not source-owned. -->
        <Class name="~(lnrpc|routerrpc|invoicesrpc)\..*"/>
    </Match>
    <Match>
        <!-- Lombok can emit redundant null checks for generated code paths; this is not actionable in source. -->
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <!-- FindSecBugs SPRING_ENDPOINT is an endpoint inventory signal, not a vulnerability finding. -->
        <Class name="~com\.aratiri\..*API"/>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>
    <Match>
        <!-- Existing parameterized application logs need a coordinated sanitization policy; keep this detector baselined until that refactor. -->
        <Class name="~com\.aratiri\..*"/>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>
    <Match>
        <!-- Spring-managed beans intentionally retain injected collaborators; SpotBugs treats DI as exposed representation. -->
        <Class name="~com\.aratiri\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <!-- Baseline existing low-priority locale/formatting findings; they are tracked as non-blocking cleanup, while new unbaselined detectors still fail the build. -->
        <Class name="~com\.aratiri\..*"/>
        <Bug pattern="DM_CONVERT_CASE,DM_DEFAULT_ENCODING,FORMAT_STRING_MANIPULATION,IMPROPER_UNICODE,NM_CONFUSING"/>
    </Match>
    <Match>
        <!-- Existing flow-control and configuration-path warnings require domain review before changing runtime behavior. -->
        <Class name="~com\.aratiri\..*"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW,NP_LOAD_OF_KNOWN_NULL_VALUE,PATH_TRAVERSAL_IN,REC_CATCH_EXCEPTION,THROWS_METHOD_THROWS_RUNTIMEEXCEPTION,UNSAFE_HASH_EQUALS,UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR,DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
</FindBugsFilter>
