                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.pr) pm.environment.set('generatedLnurlInvoice', json.pr);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/lnurl/callback/{{aliceAliasLocal}}?amount={{lnurlAmountMsat}}&comment={{lnurlComment}}"
          },
          "response": []
        },
        {
          "name": "Decode Alice Alias",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{bobAccessToken}}"}
            ],
            "url": "{{baseUrl}}/v1/decoder?input={{aliceAlias}}",
            "description": "Authenticated decode call. The current local app requires JWT here."
          },
          "response": []
        },
        {
          "name": "Decode Alice LNURL",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{bobAccessToken}}"}
            ],
            "url": "{{baseUrl}}/v1/decoder?input={{aliceLnurl}}"
          },
          "response": []
        }
      ]
