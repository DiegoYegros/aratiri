{
  "info": {
    "_postman_id": "491e93b2-7394-4b47-a164-b414706eef46",
    "name": "Aratiri Local",
    "description": "Curated local Postman collection for Aratiri. Uses the seeded Alice and Bob users from Flyway and groups requests by domain, including idempotent payment commands and the projected cursor-based transaction API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Demo Flow",
      "description": "Run these requests from top to bottom against the local seeded data.",
      "item": [
        {
          "name": "01 Login Alice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('aliceAccessToken', json.accessToken);",
                  "pm.environment.set('aliceRefreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{aliceEmail}}\",\n  \"password\": \"{{alicePassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/v1/auth/login",
            "description": "Seeded local user. Verified to work with password123."
          },
          "response": []
        },
        {
          "name": "02 Login Bob",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
