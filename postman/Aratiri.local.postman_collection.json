            ],
            "url": "{{baseUrl}}/v1/payments/invoice",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice\": \"{{generatedInvoice}}\",\n  \"feeLimitSat\": {{feeLimitSat}},\n  \"timeoutSeconds\": {{timeoutSeconds}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Replays the stored response when the body and Idempotency-Key match the original payment request."
          },
          "response": []
        },
        {
          "name": "Estimate On-Chain Fee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/payments/onchain/estimate-fee",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{onchainDestinationAddress}}\",\n  \"sats_amount\": {{onchainSatsAmount}},\n  \"target_conf\": {{onchainTargetConf}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Send On-Chain Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{onchainPaymentIdempotencyKey}}"
              }
            ],
            "url": "{{baseUrl}}/v1/payments/onchain",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{onchainDestinationAddress}}\",\n  \"sats_amount\": {{onchainSatsAmount}},\n  \"target_conf\": {{onchainTargetConf}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('onchainPaymentIdempotencyKey')) {",
                  "  pm.environment.set('onchainPaymentIdempotencyKey', 'onchain-pay-' + Date.now());",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.transactionId) pm.environment.set('latestOnchainTransactionId', json.transactionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Replay Latest On-Chain Payment",
