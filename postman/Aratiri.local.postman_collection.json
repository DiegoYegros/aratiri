    {
      "name": "Transactions",
      "item": [
        {
          "name": "Bob List Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/transactions?limit={{transactionLimit}}",
            "description": "Fast projected transaction list with cursor pagination."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.nextCursor) pm.environment.set('transactionCursor', json.nextCursor);",
                  "if (json.transactions && json.transactions[0]) pm.environment.set('latestTransactionId', json.transactions[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Bob List Transactions Next Page",
