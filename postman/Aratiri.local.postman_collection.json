                  "pm.environment.set('aliceAlias', json.alias);",
                  "pm.environment.set('aliceLnurl', json.lnurl);",
                  "pm.environment.set('aliceBitcoinAddress', json.bitcoin_address);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{aliceAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/accounts/account",
            "description": "This response already contains the account QR data as base64 fields."
          },
          "response": []
        },
        {
          "name": "05 Alice Public LNURL Metadata",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('aliceLnurlCallback', json.callback);",
                  "pm.environment.set('lnurlPaymentIdempotencyKey', 'lnurl-pay-' + Date.now());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/.well-known/lnurlp/{{aliceAliasLocal}}"
          },
          "response": []
        },
        {
          "name": "06 Alice Generate Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('generatedInvoice', json.payment_request);",
                  "pm.environment.set('invoicePaymentIdempotencyKey', 'invoice-pay-' + Date.now());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{aliceAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sats_amount\": {{invoiceSats}},\n  \"memo\": \"{{invoiceMemo}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/v1/invoices"
          },
          "response": []
        },
        {
          "name": "07 Bob Decode Generated Invoice",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/invoices/invoice/decode/{{generatedInvoice}}"
          },
          "response": []
        },
        {
          "name": "08 Bob Pay Generated Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('latestTransactionId', json.transactionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{invoicePaymentIdempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice\": \"{{generatedInvoice}}\",\n  \"feeLimitSat\": {{feeLimitSat}},\n  \"timeoutSeconds\": {{timeoutSeconds}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/v1/payments/invoice"
          },
          "response": []
        },
        {
          "name": "09 Bob List Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/transactions?limit={{transactionLimit}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.nextCursor) pm.environment.set('transactionCursor', json.nextCursor);",
                  "if (json.transactions && json.transactions[0]) pm.environment.set('latestTransactionId', json.transactions[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "10 Bob Get Latest Transaction",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bobAccessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/transactions/{{latestTransactionId}}"
          },
          "response": []
        }
      ]
    },
